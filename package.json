    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/monperrus/realtime-collaborative.git"
  },
  "bugs": {
    "url": "https://github.com/monperrus/realtime-collaborative/issues"
  },
  "homepage": "https://github.com/monperrus/realtime-collaborative#readme",
  "scripts": {
    "check": "node --check watcher.js",
    "test": "npm run check",
    "prepack": "npm run test",
    "prepublishOnly": "npm run test"
  },
  "dependencies": {
    "@hocuspocus/provider": "^2.14.1",
    "chokidar": "^4.0.3",
    "ws": "^8.18.1",
    "yjs": "^13.6.27"
  }
}
