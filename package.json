{
  "name": "@gakoy/collab",
  "version": "0.1.0",
  "description": "Share a local folder for real-time collaborative editing from any browser.",
  "type": "module",
  "bin": {
    "gakoy-collab": "./watcher.js"
  },
  "files": [
